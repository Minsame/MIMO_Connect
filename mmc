#!/usr/bin/env bash
# MIMO_Connect 命令行启动器（Linux / macOS）。
#
# 引擎在后台运行，前台只打印启动结果即返回，不常驻刷日志。
# 常用子命令：
#   ./mmc            启动引擎（后台）
#   ./mmc restart    重启引擎（重新读取 .env / config.yaml）；可简写 res
#   ./mmc stop       停止后台引擎
#   ./mmc status     查看运行状态
#   ./mmc config     调起配置引导，完成后自动重启引擎
#   ./mmc logs -f    实时跟随日志（Ctrl-C 退出）
#   ./mmc help       查看完整帮助
#
# 本脚本只负责选 Python 并把全部参数透传给 cli_main.py。
set -euo pipefail

# 解析脚本所在目录（支持软链接）。
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
cd "$ROOT"

# 选择 Python：优先项目 venv，其次 python3。
if [ -x "$ROOT/.venv/bin/python" ]; then
  PY="$ROOT/.venv/bin/python"
else
  PY="$(command -v python3 || command -v python || true)"
fi
if [ -z "${PY:-}" ]; then
  echo "[mmc] 未找到 Python，请先安装 Python 3.10+。" >&2
  exit 1
fi

# 透传参数（如 --force-setup）。
exec "$PY" cli_main.py "$@"

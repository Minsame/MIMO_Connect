# ============================================
# LLM API Keys（按需配置，未配置的提供商不会被加载）
# ============================================

# DeepSeek (国内直连，无需翻墙)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# SiliconFlow (中转站，DeepSeek 模型通过 OpenRouter 协议)
SILICONFLOW_API_KEY=sk-your-siliconflow-key

# DashScope (阿里云，OpenAI 兼容协议)
DASHSCOPE_API_KEY=sk-your-dashscope-key

# ============================================
# MiMo TTS (语音合成)
# API 地址: https://api.xiaomimimo.com/v1
# 模型: mimo-v2.5-tts (预置音色)
# 预置音色: mimo_default, 冰糖, 茉莉, 苏打, 白桦, Mia, Chloe, Milo, Dean
# ============================================
MIMO_API_KEY=your-mimo-key

# ============================================
# 运行平台 (MIMO_Connect)
# weixin - 微信 iLink Bot
# feishu - 飞书机器人 (WebSocket 长连接)
# ============================================
MIMO_CONNECT_PLATFORM=weixin

# ============================================
# 微信 iLink Bot（仅 weixin 平台需要）
# ============================================
WEIXIN_TOKEN=your-weixin-token
WEIXIN_BOT_ID=your-bot-id

# ============================================
# 飞书机器人（仅 feishu 平台需要）
# 在飞书开放平台创建应用，开启机器人能力
# 需要权限: im:message, im:message.p2p_msg:readonly, im:message.group_at_msg:readonly
# ============================================
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# ============================================
# ASR 服务（暂不需要，微信自动转文字）
# ============================================
# AZURE_SPEECH_KEY=your-azure-key
# AZURE_SPEECH_REGION=eastasia
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# ============================================
# CLI Bridge
# ============================================
# CLI 工具路径（如果不在 PATH 中）
MIMO_CODE_PATH=/path/to/mimo-code

# MiMo Code 工作目录；要操作 E:\Project_AI 下的项目时建议设为 E:\Project_AI
MIMO_CONNECT_WORK_DIR=E:\Project_AI

# ============================================
# 界面语言（GUI 与 CLI 共用）
# zh - 简体中文 ; en - English ; 留空则按系统语言自动判断
# ============================================
MIMO_CONNECT_LANG=zh
